# Polymarket Bot Credentials
# Copy this file to .env and fill in your values

# Private key (hex, without 0x prefix)
PK=

# Your wallet address on Polygon
FUNDER=

# Optional: pre-generated API credentials (leave blank to auto-derive from PK)
API_KEY=
API_SECRET=
API_PASSPHRASE=

# --- Strategy 1: Momentum (main channel) ---
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
SLACK_TICK_WEBHOOK_URL=

# --- Strategy 2: Contrarian (separate channel recommended) ---
# Falls back to SLACK_WEBHOOK_URL if left blank
SLACK_WEBHOOK_URL_CONTRARIAN=
SLACK_TICK_WEBHOOK_URL_CONTRARIAN=

# --- Strategy 3: Timed (separate channel recommended) ---
# Falls back to SLACK_WEBHOOK_URL if left blank
SLACK_WEBHOOK_URL_TIMED=
SLACK_TICK_WEBHOOK_URL_TIMED=
