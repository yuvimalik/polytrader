# Polymarket Bot Credentials
# Copy this file to .env and fill in your values

# Private key (hex, without 0x prefix)
PK=

# Your wallet address on Polygon
FUNDER=

# Optional: pre-generated API credentials (leave blank to auto-derive from PK)
API_KEY=
API_SECRET=
API_PASSPHRASE=

# Optional: Slack incoming webhook URL for trade/error/heartbeat notifications
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# Optional: Slack webhook for frequent tick/price updates (separate channel recommended)
SLACK_TICK_WEBHOOK_URL=
